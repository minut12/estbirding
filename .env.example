# Copy to .env and fill in actual values. .env is gitignored.

# Supabase — client-side (Vite-exposed)
VITE_SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Supabase — duplicate names used by non-Vite contexts (scripts, edge fn local dev)
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""

# Translation API endpoint (Cloudflare worker / Netlify function). Optional.
VITE_TRANSLATE_API_URL=""

# Server-side only — DO NOT commit values. Configure in Supabase Secrets / n8n / hosting env:
#   SPECIES_PREDICTION_N8N_WEBHOOK_URL
#   VAATLUSTE_WEBHOOK_SECRET / N8N_VAATLUSTE_WEBHOOK_SECRET
#   N8N_VAATLUSTE_WEBHOOK_URL / N8N_TOENAOSUS_WEBHOOK_URL / N8N_TOENAOSUS_WEBHOOK_SECRET
#   EBIRD_API_TOKEN
#   OPENAI_API_KEY / OPENAI_MODEL
#   ANTHROPIC_API_KEY
#   VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT
#   SUPABASE_SERVICE_ROLE_KEY (in GitHub Actions only)
